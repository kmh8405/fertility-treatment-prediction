.vscode/

# --- Python 관련 ---
# 파이썬 실행 시 생성되는 컴파일 파일들
__pycache__/
*.py[cod]
*$py.class

# --- Jupyter Notebook 관련 ---
# 노트북 실행 시 생기는 체크포인트 파일 (필수!)
.ipynb_checkpoints/

# --- macOS / OS 관련 ---
# 맥 전용 숨김 파일 (이미 넣으셨지만 확실히 하기 위해)
.DS_Store
Thumbs.db

# --- 데이터 및 결과물 (용량 및 보안) ---
# 데이터 폴더 전체 (이미 data/ 가 있지만 하위 파일 포함 명시)
data/
# 훈련시킨 모델 파일 (.pkl, .bin, .model 등)
*.pkl
*.joblib
*.model
*.h5

# 제출용 파일 (submissions 폴더가 이미 있지만, 개별 csv도 방지)
submissions/
submission_*.csv

# --- 환경 설정 및 가상환경 ---
# 가상환경 (이미 .venv/ 가 있지만 일반적인 이름들 추가)
.venv/
env/
.env

# --- 모델 관련 ---
catboost_info/tmp*.csv
notebooks/*.csv
notebooks/*.csv
